{
    "Routes": [
    
      {
        "DownstreamPathTemplate": "/api/auth/{everything}",
        "DownstreamScheme": "http",
        "DownstreamHostAndPorts": [
          { "Host": "restaurant-service", "Port": 80 }
        ],
        "UpstreamPathTemplate": "/gateway/auth/{everything}",
        "UpstreamHttpMethod": [ "POST" ]
      },
  
     
      {
        "DownstreamPathTemplate": "/api/restaurant/{everything}",
        "DownstreamScheme": "http",
        "DownstreamHostAndPorts": [
          { "Host": "restaurant-service", "Port": 80 }
        ],
        "UpstreamPathTemplate": "/gateway/restaurant/{everything}",
        "UpstreamHttpMethod": [ "GET", "POST", "PUT", "DELETE" ]
      },
  
     
      {
        "DownstreamPathTemplate": "/api/restaurant/menus/{restaurantId}/menus",
        "DownstreamScheme": "http",
        "DownstreamHostAndPorts": [
          { "Host": "restaurant-service", "Port": 80 }
        ],
        "UpstreamPathTemplate": "/gateway/menus/{restaurantId}/menus",
        "UpstreamHttpMethod": [ "POST" ]
      },
      {
        "DownstreamPathTemplate": "/api/restaurant/menus/{restaurantId}/menus/{menuId}",
        "DownstreamScheme": "http",
        "DownstreamHostAndPorts": [
          { "Host": "restaurant-service", "Port": 80 }
        ],
        "UpstreamPathTemplate": "/gateway/menus/{restaurantId}/menus/{menuId}",
        "UpstreamHttpMethod": [ "PUT", "DELETE" ]
      },
  
      
      {
        "DownstreamPathTemplate": "/api/restaurant/menu/menuitems/{restaurantId}/menus/{menuId}/items",
        "DownstreamScheme": "http",
        "DownstreamHostAndPorts": [
          { "Host": "restaurant-service", "Port": 80 }
        ],
        "UpstreamPathTemplate": "/gateway/menu-items/{restaurantId}/menus/{menuId}/items",
        "UpstreamHttpMethod": [ "GET", "POST" ]
      },
      {
        "DownstreamPathTemplate": "/api/restaurant/menu/menuitems/{restaurantId}/menus/{menuId}/items/{menuItemId}",
        "DownstreamScheme": "http",
        "DownstreamHostAndPorts": [
          { "Host": "restaurant-service", "Port": 80 }
        ],
        "UpstreamPathTemplate": "/gateway/menu-items/{restaurantId}/menus/{menuId}/items/{menuItemId}",
        "UpstreamHttpMethod": [ "GET", "PUT", "DELETE" ]
      }
  
    ],
  
    "GlobalConfiguration": {
      "BaseUrl": "http://localhost:5000"
    }
  }